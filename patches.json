{
  "meta": {
    "version": "2.7.1",
    "description": "Demo-Updatepaket fuer SeedWorld Patch Manager",
    "author": "Codex",
    "createdAt": "2026-03-27T00:00:00Z"
  },
  "patches": [
    {
      "id": "patch-001",
      "name": "README Hinweis aktualisieren",
      "type": "string-replace",
      "file": "README.md",
      "find": "SeedWorld ist ein technischer Browser-Prototyp mit **Patch-Only-Kernel**.",
      "replace": "SeedWorld ist ein technischer Browser-Prototyp mit **Patch-Only-Kernel** und Browser-Patch-Manager.",
      "stopOnError": true,
      "verify": {
        "type": "contains",
        "file": "README.md",
        "text": "Browser-Patch-Manager"
      }
    },
    {
      "id": "patch-002",
      "name": "Version in package.json anheben",
      "type": "json-update",
      "file": "package.json",
      "updates": {
        "version": "2.7.1"
      },
      "verify": {
        "type": "json-field",
        "file": "package.json",
        "field": "version",
        "expectedValue": "2.7.1"
      }
    },
    {
      "id": "patch-003",
      "name": "Patch-Changelog anlegen",
      "type": "file-create",
      "file": "docs/PATCH_2.7.1.md",
      "content": "# Patch 2.7.1\n\n- README Hinweis erweitert\n- package.json Version aktualisiert\n",
      "verify": {
        "type": "file-exists",
        "file": "docs/PATCH_2.7.1.md"
      }
    }
  ]
}
